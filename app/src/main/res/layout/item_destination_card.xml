<?xml version="1.0" encoding="utf-8"?>
<!--
    item_destination_card.xml
    [F3] Custom row layout inflated by DestinationAdapter's ViewHolder
         for every item in the RecyclerView.
    Each row displays: emoji bubble | name, region, category pill, rating | price
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginEnd="6dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <!-- Emoji / icon bubble -->
        <TextView
            android:id="@+id/tv_dest_emoji"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:textSize="28sp"
            android:background="@drawable/emoji_bubble_bg"
            tools:text="🏔️" />

        <!-- Main text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tv_dest_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Hunza Valley" />

            <TextView
                android:id="@+id/tv_dest_region"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#BDBDBD"
                android:textSize="12sp"
                tools:text="Gilgit-Baltistan" />

            <!-- Category pill + star rating -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_dest_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/category_pill_bg"
                    android:textColor="@color/accent_orange"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="Mountains" />

                <TextView
                    android:id="@+id/tv_dest_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textColor="#FFD740"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="★ 4.9" />

            </LinearLayout>

        </LinearLayout>

        <!-- Price + chevron column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tv_dest_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_orange_light"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="PKR 8500/night" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="›"
                android:textColor="#757575"
                android:textSize="20sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
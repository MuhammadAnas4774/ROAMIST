<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark"
    tools:context=".activities.SignupActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/signup_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_dark"
        android:elevation="4dp"
        app:title="@string/signup_title"
        app:titleTextColor="@color/accent_orange"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <!-- ── Branding Header ── -->
        <TextView
            android:id="@+id/tv_app_name_signup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="ROAMIST"
            android:textColor="@color/accent_orange"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.18" />

        <!-- Orange accent underline -->
        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/orange_divider" />

        <TextView
            android:id="@+id/tv_tagline_signup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Discover Pakistan, one trip at a time"
            android:textColor="#BDBDBD"
            android:textSize="14sp"
            android:layout_marginBottom="40dp" />

        <!-- ── Signup Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_signup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="20dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="36dp"
                android:paddingBottom="36dp">

                <!-- Card Title -->
                <TextView
                    android:id="@+id/tv_card_title_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_card_subtitle_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fill in the details to get started"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:layout_marginBottom="28dp" />

                <!-- Full Name -->
                <TextView
                    android:id="@+id/label_full_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_background"
                    android:hint="Enter your full name"
                    android:textColorHint="#757575"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:layout_marginBottom="20dp" />

                <!-- Email -->
                <TextView
                    android:id="@+id/label_email_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_email_signup"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_background"
                    android:hint="example@email.com"
                    android:textColorHint="#757575"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:layout_marginBottom="20dp" />

                <!-- Phone Number -->
                <TextView
                    android:id="@+id/label_phone_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_phone_signup"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_background"
                    android:hint="+92 3xx-xxxxxxx"
                    android:textColorHint="#757575"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="phone"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:layout_marginBottom="20dp" />

                <!-- Password -->
                <TextView
                    android:id="@+id/label_password_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_password_signup"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_background"
                    android:hint="Create a strong password"
                    android:textColorHint="#757575"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPassword"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:layout_marginBottom="20dp" />

                <!-- Confirm Password -->
                <TextView
                    android:id="@+id/label_confirm_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_background"
                    android:hint="Re-enter your password"
                    android:textColorHint="#757575"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:layout_marginBottom="10dp" />

                <!-- Terms note -->
                <TextView
                    android:id="@+id/tv_terms_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="By signing up you agree to our Terms of Service and Privacy Policy."
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="28dp" />

                <!-- Signup Button -->
                <Button
                    android:id="@+id/btn_signup"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Create Account"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_ripple"
                    android:layout_marginBottom="20dp" />

                <!-- Divider with OR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#3A3A3A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  or continue with  "
                        android:textColor="#757575"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#3A3A3A" />
                </LinearLayout>

                <!-- Google sign-in (text only, no image) -->
                <Button
                    android:id="@+id/btn_google_signup"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="G  Continue with Google"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:background="@drawable/section_card_background"
                    android:layout_marginBottom="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bottom link: already have account -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginTop="28dp">

            <TextView
                android:id="@+id/tv_already_have_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account?  "
                android:textColor="#9E9E9E"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_go_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="@color/accent_orange"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>

    </ScrollView>
</LinearLayout>

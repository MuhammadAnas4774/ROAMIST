<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_destination_detail.xml
    [F2] Displays all fields of a Destination received from a Bundle (Parcelable).
    [F4] This fragment is loaded via a Fragment Transaction from DashboardActivity.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:scrollbars="none"
    tools:context=".fragments.DestinationDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ── Hero Section ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/surface_dark">

            <!-- [F2] Filled from Bundle: dest.iconEmoji -->
            <TextView
                android:id="@+id/tv_detail_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="72sp"
                android:gravity="center"
                tools:text="🏔️" />

        </LinearLayout>

        <!-- ── Content Card (overlaps hero by -24 dp) ───────────────────── -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="-24dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <!-- [F2] dest.name -->
                <TextView
                    android:id="@+id/tv_detail_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="Hunza Valley" />

                <!-- [F2] dest.region -->
                <TextView
                    android:id="@+id/tv_detail_region"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#BDBDBD"
                    android:textSize="14sp"
                    tools:text="📍 Gilgit-Baltistan" />

                <!-- [F2] dest.category -->
                <TextView
                    android:id="@+id/tv_detail_category_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:background="@drawable/category_pill_bg"
                    android:textColor="@color/accent_orange"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="Mountains" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="#3A3A3A" />

                <!-- Stats row: Rating | Price -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Rating stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rating"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <!-- [F2] dest.rating -->
                        <TextView
                            android:id="@+id/tv_detail_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#FFD740"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="★ 4.9 / 5.0" />

                    </LinearLayout>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#3A3A3A" />

                    <!-- Price stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Price"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <!-- [F2] dest.pricePerNight -->
                        <TextView
                            android:id="@+id/tv_detail_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/accent_orange_light"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="PKR 8,500 / night" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    android:background="#3A3A3A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About this destination"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- [F2] dest.description -->
                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#BDBDBD"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.6"
                    tools:text="A breathtaking valley surrounded by the Karakoram Range…" />

                <!-- Plan Trip CTA -->
                <Button
                    android:id="@+id/btn_plan_trip"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="Plan My Trip →"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_ripple" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>

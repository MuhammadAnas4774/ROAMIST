<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/coming_soon_bg"
    tools:context=".MapsActivity">

    <!-- ── AppBar ── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/map_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        android:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/map_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Map Explorer"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="@drawable/ic_location"
            app:navigationIconTint="@color/accent_orange"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Body ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- ══════════════════════════════════════
                 DECORATIVE MAP GRID (dots — no image)
            ═══════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp">

                <!-- Faint grid lines — H -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="44dp"
                    android:background="#1AFFFFFF" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="88dp"
                    android:background="#1AFFFFFF" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="132dp"
                    android:background="#1AFFFFFF" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="176dp"
                    android:background="#1AFFFFFF" />

                <!-- Faint grid lines — V -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:layout_marginStart="72dp"
                    android:background="#1AFFFFFF" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:layout_marginStart="144dp"
                    android:background="#1AFFFFFF" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:layout_marginStart="216dp"
                    android:background="#1AFFFFFF" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:layout_marginStart="288dp"
                    android:background="#1AFFFFFF" />

                <!-- Decorative orange map-dots -->
                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="65dp"
                    android:layout_marginTop="37dp"
                    android:background="@drawable/map_dot" />

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="137dp"
                    android:layout_marginTop="81dp"
                    android:background="@drawable/map_dot" />

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="209dp"
                    android:layout_marginTop="125dp"
                    android:background="@drawable/map_dot" />

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="281dp"
                    android:layout_marginTop="37dp"
                    android:background="@drawable/map_dot" />

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="65dp"
                    android:layout_marginTop="169dp"
                    android:background="@drawable/map_dot" />

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="209dp"
                    android:layout_marginTop="37dp"
                    android:background="@drawable/map_dot" />

                <!-- Large centre pin dot -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:background="@drawable/map_dot" />

                <!-- Pulse rings around centre pin -->
                <View
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:background="@drawable/map_dot"
                    android:alpha="0.35" />

                <View
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center"
                    android:background="@drawable/map_dot"
                    android:alpha="0.15" />

                <!-- Centre label -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="80dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="32sp"
                        android:gravity="center" />
                </LinearLayout>

            </FrameLayout>

            <!-- ══════════════════════════════════════
                 COMING SOON HEADLINE
            ═══════════════════════════════════════ -->
            <TextView
                android:id="@+id/tv_coming_soon_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="COMING SOON"
                android:textColor="@color/accent_orange"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.20"
                android:layout_marginBottom="10dp" />

            <!-- Accent underline -->
            <View
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/orange_divider"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_map_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Interactive Map Explorer"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_map_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We are building a powerful real-time map experience for Pakistan — discover routes, hotels, restaurants, and attractions across every province, all in one place."
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="32dp" />

            <!-- ══════════════════════════════════════
                 FEATURE TEASER CARDS
            ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="@drawable/orange_divider"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What's coming"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Feature 1 -->
            <LinearLayout
                android:id="@+id/feature_card_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/feature_card_border"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:text="🗺️"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live Route Navigation"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Turn-by-turn directions to every destination across Pakistan"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </LinearLayout>

            <!-- Feature 2 -->
            <LinearLayout
                android:id="@+id/feature_card_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/feature_card_border"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:text="📍"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nearby POI Discovery"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instantly find hotels, restaurants, mosques, and fuel stops near you"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </LinearLayout>

            <!-- Feature 3 -->
            <LinearLayout
                android:id="@+id/feature_card_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/feature_card_border"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:text="🌤️"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weather Overlay"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Real-time weather conditions overlaid on the map for your travel region"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </LinearLayout>

            <!-- Feature 4 -->
            <LinearLayout
                android:id="@+id/feature_card_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/feature_card_border"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:text="📡"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offline Map Support"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Download maps for remote areas like GB, AJK, and Balochistan to use without internet"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </LinearLayout>

            <!-- ══════════════════════════════════════
                 NOTIFY ME CARD
            ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_notify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get Notified When It Launches"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Be the first to explore Pakistan through\nRoamist's interactive map."
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="24dp" />

                    <Button
                        android:id="@+id/btn_notify_me"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Notify Me"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_ripple"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_go_explore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Explore Destinations Instead →"
                        android:textColor="@color/accent_orange"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>